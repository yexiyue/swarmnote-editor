{
  "name": "@swarmnote/editor-react",
  "version": "0.1.1",
  "license": "MIT",
  "description": "React plumbing for @swarmnote/editor-core: EditorView mount wrapper + I18nProvider. UI primitives are distributed via the shadcn-style registry.",
  "type": "module",
  "homepage": "https://github.com/swarm-apps/swarmnote-editor#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/swarm-apps/swarmnote-editor.git",
    "directory": "packages/editor-react"
  },
  "bugs": {
    "url": "https://github.com/swarm-apps/swarmnote-editor/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm build"
  },
  "peerDependencies": {
    "@swarmnote/editor-core": "workspace:*",
    "lucide-react": "^0.500.0",
    "radix-ui": "^1",
    "react": "^19",
    "react-dom": "^19"
  },
  "peerDependenciesMeta": {
    "lucide-react": {
      "optional": true
    },
    "radix-ui": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "lucide-react": "^0.500.0",
    "radix-ui": "^1.4.3",
    "react": "^19",
    "react-dom": "^19",
    "typescript": "~5.9.2"
  }
}
