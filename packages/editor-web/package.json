{
  "name": "@swarmnote/editor-web",
  "version": "0.2.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "description": "WebView runtime + Comlink bridge for @swarmnote/editor-react-native. Bundles CodeMirror via vite-plugin-singlefile into a self-contained HTML asset.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./contracts": "./contracts.ts",
    "./dist/index.html": "./dist/index.html"
  },
  "files": [
    "dist",
    "src",
    "contracts.ts",
    "index.html",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@swarmnote/editor-core": "workspace:*"
  },
  "dependencies": {
    "comlink": "^4.4.2",
    "katex": "^0.16.45",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.20"
  },
  "devDependencies": {
    "typescript": "~5.9.2",
    "vite": "^8.0.8",
    "vite-plugin-singlefile": "^2.3.2"
  }
}
